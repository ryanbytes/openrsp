+        if (channel == 0) return deviceParams->rxChannelA;
+        if (channel == 1) return deviceParams->rxChannelB;
+        throw std::out_of_range("invalid RSPduo RX channel");
+    }
+    if (channel != 0) throw std::out_of_range("invalid RSP RX channel");
+    return chParams;
+}
+
+sdrplay_api_TunerSelectT SoapySDRPlay::channelTuner(const size_t channel) const
+{
+    if (device.rspDuoMode == sdrplay_api_RspDuoMode_Dual_Tuner)
+    {
+        if (channel == 0) return sdrplay_api_Tuner_A;
+        if (channel == 1) return sdrplay_api_Tuner_B;
+        throw std::out_of_range("invalid RSPduo RX channel");
+    }
+    if (channel != 0) throw std::out_of_range("invalid RSP RX channel");
+    return device.tuner;
+}
